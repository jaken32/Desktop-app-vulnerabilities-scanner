# Copy to .env (which is gitignored) and adjust as needed. All optional —
# deskscanner runs with sensible defaults and needs no secrets to operate.

# Skip the interactive authorization prompt (e.g. for CI). Set to "1" only when
# you have authorization to scan the target. Equivalent to passing --yes.
DESKSCANNER_ASSUME_YES=0

# Host/port for the local web UI (`deskscanner serve`).
DESKSCANNER_WEB_HOST=127.0.0.1
DESKSCANNER_WEB_PORT=8765

# Per-request timeout (seconds) for the loopback local-API probe.
DESKSCANNER_PROBE_TIMEOUT=4.0

# Resource limits for safe asar unpacking (zip-bomb defense).
DESKSCANNER_MAX_TOTAL_BYTES=536870912     # 512 MiB total uncompressed
DESKSCANNER_MAX_FILE_BYTES=67108864       # 64 MiB per file
DESKSCANNER_MAX_FILES=200000              # max file entries
DESKSCANNER_UNPACK_TIMEOUT=120            # wall-clock seconds
